{
  "version": 2,
  "builds": [
    {
      "src": "wafungi_nation/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb",
        "runtime": "python3.11"
      }
    },
    {
      "src": "static/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/media/(.*)",
      "dest": "/media/$1"
    },
    {
      "src": "/(.*)",
      "dest": "wafungi_nation/wsgi.py"
    }
  ],
  "env": {
    "DJANGO_SETTINGS_MODULE": "wafungi_nation.settings",
    "DEBUG": "False"
  },
  "outputDirectory": "staticfiles"
}